        "vue3",
        "tailwindcss",
        "javascript",
        "ui",
        "components",
        "component-library"
    ],
    "author": "MoYuan-CN and PCL-Community",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PCL-Community/Plain.UI.git",
        "directory": "packages/vue-tailwind-js"
    },
    "bugs": {
        "url": "https://github.com/PCL-Community/Plain.UI/issues"
    },
    "homepage": "https://github.com/PCL-Community/Plain.UI#readme",
    "peerDependencies": {
        "vue": "^3.4.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^5.2.0",
        "vue": "^3.4.0"
    }

{
    "name": "@pcl-community/plain-ui-vue-tailwind-js",
    "version": "1.0.1",
    "description": "Plain UI - Vue 3 + TailwindCSS + JavaScript",
    "type": "module",
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.js",

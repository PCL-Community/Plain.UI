        "build": "vite build",
        "preview": "vite preview",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com"
    },
    "keywords": [
        "pcl-community",
        "plain-ui",

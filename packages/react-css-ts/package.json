{
    "name": "@pcl-community/plain-ui-react-css-ts",
    "version": "1.1.0",
    "description": "Plain UI - React + CSS + TypeScript",
    "type": "module",
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs",
            "types": "./dist/index.d.ts"
        },
        "./style.css": "./dist/style.css",
        "./theme.css": "./dist/theme.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com"
    },
    "keywords": [
        "pcl-community",
        "plain-ui",
        "react",
        "react18",
        "css",
        "typescript",
        "ui",
        "components",
        "component-library"
    ],
    "author": "MoYuan-CN and PCL-Community",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PCL-Community/Plain.UI.git",
        "directory": "packages/react-css-ts"
    },
    "bugs": {
        "url": "https://github.com/PCL-Community/Plain.UI/issues"
    },
    "homepage": "https://github.com/PCL-Community/Plain.UI#readme",
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.0",
        "typescript": "^5.4.0",
        "vite": "^5.2.0",
        "vite-plugin-dts": "^3.9.0",
        "vite-plugin-lib-inject-style": "^0.1.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    }
}
